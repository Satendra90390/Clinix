# ClinixAI Environment Configuration
# Copy this to .env and update values

# Database path (SQLite file) or PostgreSQL URL
DATABASE_URL=sqlite:///clinixai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/clinixai

# Server configuration
PORT=8000
WORKERS=4

# CORS - comma separated allowed origins (use * for development only)
ALLOWED_ORIGINS=*

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Security Configuration
SECRET_KEY=your-secret-key-change-in-production-min-32-chars

# Google OAuth Configuration (for Google Sign-In)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Twilio Configuration (for Phone/SMS Authentication)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
